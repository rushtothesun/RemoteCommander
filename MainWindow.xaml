<Window x:Class="RemoteCommander.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RemoteCommander"
        mc:Ignorable="d"
        Title="Remote Commander" Height="800" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#FF202020"
        Foreground="White"
        Topmost="{Binding Path=AlwaysOnTop}"
        Opacity="{Binding Path=WindowOpacity}">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="18" Height="18">
                                <Path x:Name="checkMark" Data="M 0 6 L 4 10 L 10 0" StrokeThickness="2" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DPB Style GroupBox -->
        <Style x:Key="DPBGroupBox" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#FF114BB5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header Bar -->
                            <Border Grid.Row="0" Background="#FF114BB5" Padding="5,4,5,4">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                            </Border>
                            <!-- Content Area -->
                            <Border Grid.Row="1" BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="1,0,1,1" Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root" Background="#FF1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar for Borderless Dragging -->
        <Border Grid.Row="0" Background="#FF114BB5" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Remote Commander" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Width="30" Background="Transparent" Foreground="White" BorderThickness="0" Click="Minimize_Click" />
                    <Button Content="X" Width="30" Background="Transparent" Foreground="White" BorderThickness="0" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Remote Bots Setup -->
        <GroupBox Grid.Row="1" Margin="5" Style="{StaticResource DPBGroupBox}">
            <GroupBox.Header>
                <TextBlock Text="REMOTE BOTS (IP:PORT)" Foreground="White" FontSize="11" />
            </GroupBox.Header>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="IP:Port " VerticalAlignment="Center" Foreground="White"/>
                    <TextBox x:Name="NewBotAddress" Width="140" Margin="5,0"/>
                    <TextBlock Text="Label " VerticalAlignment="Center" Foreground="White" Margin="5,0"/>
                    <TextBox x:Name="NewBotLabel" Width="120" Margin="5,0" />
                    <Button Content="ADD" Margin="10,0,5,0" Padding="15,4" Click="AddBot_Click" Background="#FF333333" Foreground="White" BorderBrush="Gray" BorderThickness="1"/>
                    <Button Content="UPDATE" Margin="5,0" Padding="15,4" Click="UpdateBot_Click" Background="#FF333333" Foreground="White" BorderBrush="Gray" BorderThickness="1"/>
                    <Button Content="REMOVE" Margin="5,0" Padding="15,4" Click="RemoveBot_Click" Background="#FF333333" Foreground="White" BorderBrush="Gray" BorderThickness="1"/>
                </StackPanel>
                <TextBlock Text="Format: IP:Port in first box, display name in second box" 
                           FontSize="10" Foreground="Gray" Margin="10,0,5,2" />
                <ListBox x:Name="BotListBox"
                         Height="60"
                         Margin="5"
                         SelectionMode="Single" 
                         SelectionChanged="BotListBox_SelectionChanged"
                         Background="#FF1A1A1A" Foreground="White" BorderBrush="Gray" />
                
                <StackPanel Orientation="Horizontal" Margin="5,0,5,5">
                    <TextBlock Text="Window Opacity: " VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                    <Slider Minimum="0.2" Maximum="1.0" Value="{Binding Path=WindowOpacity, Mode=TwoWay}" Width="150" VerticalAlignment="Center" TickFrequency="0.01" IsSnapToTickEnabled="True" SmallChange="0.01" LargeChange="0.1" ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock Text="{Binding Path=WindowOpacity, Mode=OneWay, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="10,0,20,0" Width="40" Foreground="White"/>
                    
                    <CheckBox Content="Always Show on Top"
                              IsChecked="{Binding Path=AlwaysOnTop, Mode=TwoWay}"
                              Margin="0,0,20,0" VerticalAlignment="Center" Checked="AlwaysOnTop_Changed" Unchecked="AlwaysOnTop_Changed" Foreground="White"/>
                    
                    <CheckBox Content="Muted Colors"
                              IsChecked="{Binding Path=MutedColors, Mode=TwoWay}"
                              Margin="0,0,20,0" VerticalAlignment="Center" Checked="MutedColors_Changed" Unchecked="MutedColors_Changed" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Global Control Bar -->
        <StackPanel Grid.Row="2" Margin="5,5,5,0">
            <CheckBox x:Name="SyncAllCheckbox" Content="Sync All — commands apply to all bots at once"
                      IsChecked="True" Margin="5" FontWeight="Bold" Foreground="White"
                      Checked="SyncAllCheckbox_Changed" Unchecked="SyncAllCheckbox_Changed" />
            <TextBlock x:Name="StatusText" Text="Ready" Margin="5,0,5,5" FontSize="11" Foreground="White" />
        </StackPanel>

        <!-- Dynamic bot command panels -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="5">
            <WrapPanel x:Name="BotPanelsContainer" Orientation="Horizontal" />
        </ScrollViewer>
    </Grid>
</Window>
